{
  "name": "vapor-collector",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "devStart": "nodemon steam_auth.js",
    "startFull": "concurrently \"npm run start\" \"npm run devStart\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.5",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "cors": "^2.8.5",
    "ejc": "^1.0.0",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "jsdom": "^27.1.0",
    "nodemon": "^3.1.11",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
